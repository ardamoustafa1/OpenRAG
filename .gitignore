# ============================================================
# Enterprise RAG AI Platform — Root .gitignore
# ============================================================

# ---- Environment & Secrets ----
.env
.env.local
.env.*.local
*.secret
secrets/

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
pip-selfcheck.json
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml
*.log

# ---- Node / Next.js ----
node_modules/
.next/
out/
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo

# ---- Docker ----
.docker/

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Infra / Terraform ----
*.tfstate
*.tfstate.backup
.terraform/
*.tfvars
!*.tfvars.example

# ---- Data & Models ----
*.model
*.bin
data/
uploads/
