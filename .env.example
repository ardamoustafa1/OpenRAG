# ============================================================
# Enterprise RAG AI Platform — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
ENVIRONMENT=development         # development | staging | production
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR

# ------------------------------------------------------------
# Security (REQUIRED — generate with: openssl rand -hex 32)
# ------------------------------------------------------------
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------
# CORS (comma-separated list for production)
# In development: ["http://localhost:3000"]
# In production:  ["https://yourdomain.com"]
# ------------------------------------------------------------
# CORS_ALLOW_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ------------------------------------------------------------
# Database (PostgreSQL with pgvector)
# ------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=rag_db
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@localhost:5432/rag_db

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# Vector Database (Qdrant)
# ------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ------------------------------------------------------------
# Object Storage (MinIO)
# ------------------------------------------------------------
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_password
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=CHANGE_ME_strong_password
MINIO_SECURE=false
MINIO_BUCKET_NAME=documents

# ------------------------------------------------------------
# LLM Services
# ------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
# LITELLM_BASE_URL=http://localhost:4000

# ------------------------------------------------------------
# Observability (Langfuse — optional)
# ------------------------------------------------------------
# LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
# LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
# LANGFUSE_HOST=http://localhost:3000

# ------------------------------------------------------------
# Email / SMTP (required for password reset and notifications)
# Compatible with: SendGrid, AWS SES, Resend, Postmark, or any SMTP
# For SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_USER=apikey, SMTP_PASSWORD=<api-key>
# For Resend:   SMTP_HOST=smtp.resend.com, SMTP_PORT=465, SMTP_USER=resend, SMTP_PASSWORD=<api-key>
# ------------------------------------------------------------
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=CHANGE_ME_your_smtp_password_or_api_key
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=OpenRAG

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:3000

# ------------------------------------------------------------
# Billing (Stripe — optional, for SaaS deployments)
# ------------------------------------------------------------
# STRIPE_API_KEY=sk_test_your_stripe_api_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================================
# Docker Compose only (not read by FastAPI settings)
# ============================================================
# The above POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB,
# MINIO_ROOT_USER, MINIO_ROOT_PASSWORD are used by Docker.
# LANGFUSE_PUBLIC_KEY and LANGFUSE_SECRET_KEY are also used
# by the docker-compose.yml litellm service.

# ------------------------------------------------------------
# Grafana (Docker only)
# ------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_password

# ------------------------------------------------------------
# Langfuse internal secrets (Docker only)
# Generate with: openssl rand -hex 32
# ------------------------------------------------------------
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
LANGFUSE_SALT=CHANGE_ME_generate_with_openssl_rand_hex_32
LANGFUSE_DB_PASSWORD=CHANGE_ME_strong_password

# ------------------------------------------------------------
# Traefik Dashboard (Docker only)
# Generate with: htpasswd -nb admin your_password
# Example: admin:$$2y$$05$$... (escape $ as $$ in env files)
# ------------------------------------------------------------
TRAEFIK_DASHBOARD_CREDENTIALS=admin:$$2y$$05$$CHANGE_ME_htpasswd_hash
